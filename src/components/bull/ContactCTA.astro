---
import type { Lang } from "../../lib/i18n";
import { bullPath } from "../../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  en: {
    heading: "Work with BULL",
    body: "Cloud foundations, corporate domain and identity migrations, IaC and observability, plus architecture reviews and selected delivery engagements. Tell us what you are building.",
    cta: "Start a conversation",
  },
  ja: {
    heading: "BULLに相談する",
    body: "クラウド基盤づくり、コーポレートドメイン・ID移行、IaC・監視、アーキテクチャレビューや選択的な実装支援まで。いま取り組んでいることをお聞かせください。",
    cta: "お問い合わせ",
  },
}[lang];
---

<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div
    class="p-8 md:p-12 rounded-2xl bg-gradient-to-br from-accent-500/10 to-accent-600/5 border border-accent-500/20 text-center"
  >
    <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{copy.heading}</h2>
    <p class="text-light-muted dark:text-dark-muted mb-6 max-w-2xl mx-auto">
      {copy.body}
    </p>
    <a
      href={bullPath(lang, "/contact")}
      class="inline-flex items-center gap-2 px-8 py-4 bg-accent-500 hover:bg-accent-600 text-white font-medium rounded-lg transition-colors text-lg"
    >
      {copy.cta}
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>
